		{ "id": "e5", "fromNode": "main", "fromSide": "bottom", "toNode": "kidney", "toSide": "top" },
		{ "id": "e6", "fromNode": "main", "fromSide": "bottom", "toNode": "combined", "toSide": "top" }
	]
