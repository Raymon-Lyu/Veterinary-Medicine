	"nodes":[
		{"id":"root","type":"text","text":"# 动物传染病学各论\n\n这是一款结构化的动物传染病学复习导图。\n包含常见共患病、禽病、水禽病及猪病。","x":0,"y":0,"width":350,"height":180,"color":"2"},
